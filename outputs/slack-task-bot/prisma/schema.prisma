generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestType {
  CHECKOUT_LINK
  SPLITIT_WHITELIST
  REFUND_PAYMENT
  BUG_REPORT
  ENHANCEMENT_REQUEST
  KYC_KYB
  PAYMENT_ISSUE
  ACCOUNT_SETTINGS
  OTHER
}

enum RequestStatus {
  SUBMITTED
  IN_PROGRESS
  DONE
  CUSTOM
}

enum RequestUpdateKind {
  CREATED
  STATUS_CHANGED
  DUE_DATE_CHANGED
  BLOCKER_CHANGED
  NOTE_ADDED
  REASSIGNED
  REQUESTER_NOTIFIED
  AUTOMATION_UPDATED
}

enum UserRole {
  ADMIN
  CSM
  SALES_REP
  REQUESTER
}

enum SplititAutomationStatus {
  QUEUED
  RUNNING
  WAITING_ON_SPLITIT
  DONE
  BLOCKED
  FAILED
}

enum SplititAutomationStep {
  QUEUED
  SENT_NAME
  SENT_ROLE
  SENT_STORE_AND_EMAIL
  SENT_WHITELIST_REQUEST
  WAITING_FOR_REPLY
  COMPLETED
  BLOCKED
}

model User {
  id          String   @id @default(cuid())
  slackUserId String   @unique
  name        String?
  isAdmin     Boolean  @default(false)
  role        UserRole @default(REQUESTER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedRequests Request[]      @relation("RequestOwner")
  requestedRequests Request[]     @relation("RequestRequester")
  internalNotes    InternalNote[]
  requestUpdates   RequestUpdate[]
  channelMappings  ChannelOwnerMapping[]
  channelMemberships ChannelMember[]
}

model Channel {
  id             String   @id @default(cuid())
  slackChannelId String   @unique
  name           String?
  companyName    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requests Request[]
  ownerMapping ChannelOwnerMapping?
  members ChannelMember[]
}

model ChannelMember {
  id             String   @id @default(cuid())
  slackChannelId String
  slackUserId    String
  role           UserRole @default(REQUESTER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel Channel @relation(fields: [slackChannelId], references: [slackChannelId], onDelete: Cascade)
  user    User    @relation(fields: [slackUserId], references: [slackUserId], onDelete: Cascade)

  @@unique([slackChannelId, slackUserId])
  @@index([slackUserId])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelOwnerMapping {
  id             String   @id @default(cuid())
  slackChannelId String   @unique
  ownerSlackUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channel Channel @relation(fields: [slackChannelId], references: [slackChannelId], onDelete: Cascade)
  owner   User    @relation(fields: [ownerSlackUserId], references: [slackUserId], onDelete: Cascade)
}

model Request {
  id                    Int           @id @default(autoincrement())
  title                 String
  description           String
  type                  RequestType   @default(OTHER)
  aiTags                String[]       @default([])
  intent                String         @default("")
  extractedFields       Json           @default("{}")
  suggestedNextStep     String         @default("")
  confidence            Float          @default(0)
  status                RequestStatus @default(SUBMITTED)
  customStatus          String?
  requesterSlackUserId  String
  ownerSlackUserId      String
  channelId             String
  threadTs              String
  messageTs             String
  requesterMessageChannelId String?
  requesterMessageTs    String?
  dueDate               DateTime?
  blocker               String?
  lastReminderSentAt    DateTime?
  completedAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  requester User    @relation("RequestRequester", fields: [requesterSlackUserId], references: [slackUserId])
  owner     User    @relation("RequestOwner", fields: [ownerSlackUserId], references: [slackUserId])
  channel   Channel @relation(fields: [channelId], references: [slackChannelId])
  notes     InternalNote[]
  updates   RequestUpdate[]
  splititAutomationJob SplititAutomationJob?

  @@index([ownerSlackUserId, status])
  @@index([channelId])
  @@index([dueDate])
}

model SplititAutomationJob {
  id                    String                   @id @default(cuid())
  requestId             Int                      @unique
  targetEmail           String
  csmName               String                   @default("Mitchell Rodio")
  merchantRole          String                   @default("Merchant")
  storeName             String                   @default("Whop.com")
  merchantEmail         String                   @default("mitchell.rodio@whop.com")
  riskAcknowledgement   String                   @default("Please whitelist, I understand the risks")
  status                SplititAutomationStatus  @default(QUEUED)
  step                  SplititAutomationStep    @default(QUEUED)
  approvedBySlackUserId String?
  lastMessage           String?
  lastResponse          String?
  error                 String?
  attempts              Int                      @default(0)
  nextRunAt             DateTime                 @default(now())
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt])
}

model InternalNote {
  id        String   @id @default(cuid())
  requestId Int
  authorSlackUserId String
  body      String
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorSlackUserId], references: [slackUserId])
}

model RequestUpdate {
  id        String            @id @default(cuid())
  requestId Int
  actorSlackUserId String?
  kind      RequestUpdateKind
  message   String
  createdAt DateTime          @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorSlackUserId], references: [slackUserId])
}

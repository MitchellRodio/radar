DATABASE_URL="postgresql://postgres:postgres@localhost:5432/slack_task_bot?schema=public"

SLACK_BOT_TOKEN="xoxb-your-bot-token"
SLACK_SIGNING_SECRET="your-signing-secret"
SLACK_APP_TOKEN="xapp-your-app-level-token"

# Comma-separated Slack user IDs allowed to use admin commands and /all-requests.
ADMIN_SLACK_USER_IDS="U123ADMIN,U456ADMIN"

# Socket Mode is easiest for local development. Set to false when deploying behind HTTP.
SLACK_SOCKET_MODE="true"
PORT="3000"

# Reminder job interval in minutes.
REMINDER_INTERVAL_MINUTES="60"

# Optional; dashboard settings can store these instead.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-nano"
WHOP_API_KEY=""
